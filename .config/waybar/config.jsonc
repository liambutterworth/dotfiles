{
    "layer": "top",
    "position": "top",
    "margin-top": 8,
    "margin-left": 8,
    "margin-right": 8,
    "modules-left": ["hyprland/workspaces", "clock"],
    "modules-center": [],
    "modules-right": ["cpu", "memory", "battery"],
    "reload_style_on_change": true,

    "clock": {
        "format": "{:%H:%M}"
    },

    "battery": {
        "format": "{capacity}% {icon}",
        "format-icons": ["", "", "", "", ""]
    }
}
