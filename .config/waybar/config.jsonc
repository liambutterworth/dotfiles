{
    "layer": "top",
    "position": "top",
    "margin-top": 8,
    "margin-left": 8,
    "margin-right": 8,
    "reload_style_on_change": true,

    "modules-left": [
        "group/menu",
        "hyprland/workspaces"
    ],

    "modules-right": [
        "cpu",
        "memory",
        "battery",
        "wireplumber",
        "network",
        "custom/date",
        "custom/time"
    ],

    "group/menu": {
        "orientation": "horizontal",

        "drawer": {
            "click-to-reveal": true,
            "transition-duration": 500,
            "children-class": "option"
        },

        "modules": [
            "custom/launcher",
            "custom/divider",
            "custom/poweroff",
            "custom/reboot",
            "custom/suspend"
        ]
    },

    "custom/launcher": {
        "format": "<span font='16' rise='-2000'>َ°£‡</span>",
        "cursor": true,
        "tooltip": false
    },

    "custom/divider": {
        "format": ":"
    },

    "custom/poweroff": {
        "format": "<span font='16' rise='-2000'>âڈ»</span>",
        "on-click": "systemctl poweroff"
    },

    "custom/reboot": {
        "format": "<span font='16' rise='-2000'>ïپ‹</span>",
        "on-click": "systemctl reboot"
    },

    "custom/suspend": {
        "format": "<span font='16' rise='-2000'>ïپŒ</span>",
        "on-click": "systemctl suspend"
    },

    "hyprland/workspaces": {
        "on-click": "activate",
        "cursor": true
    },

    "cpu": {
        "format": "<span font='16' rise='-2000'>ï’¼</span> {}%",
        "interval": 10
    },

    "memory": {
        "format": "<span font='16' rise='-2000'>î؟…</span> {}%",
        "interval": 10
    },

    "battery": {
        "format": "{capacity}% {icon}",
        "format-icons": ["", "", "", "", ""]
    },

    "wireplumber": {
        "format": "<span font='16' rise='-2000'>َ°•¾</span> {volume}%",
        "format-muted": "<span font='16' rise='-2000'>َ°–پ</span> {volume}%",
        "on-click": "helvum"
    },

    "network": {
        "format": "<span font='16' rise='-2000'>{icon}</span> {ifname}",
        "format-wifi": "<span font='16' rise='-2000'>{icon}</span> {essid}",
        "format-ethernet": "<span font='16' rise='-2000'>َ°ˆ€</span> {ipaddr}/{cidr}",
        "format-disconnected": "",
        "format-icons": ["َ°¤¯", "َ°¤ں", "َ°¤¢", "َ°¤¥", "َ°¤¨"],
        "max-length": 50
    },

    "custom/date": {
        "format": "<span font='16' rise='-2000'>ï„³</span> {}",
        "exec": "date '+%a %b %d'",
        "interval": 1
    },

    "custom/time": {
        "format": "<span font='16' rise='-2000'>ï€—</span> {}",
        "exec": "date '+%-I:%M %p'",
        "interval": 1
    }
}
