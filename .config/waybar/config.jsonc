{
    "layer": "top",
    "position": "top",
    "margin-top": 8,
    "margin-left": 8,
    "margin-right": 8,
    "reload_style_on_change": true,

    "modules-left": [
        "group/menu",
        "hyprland/workspaces"
    ],

    "modules-right": [
        "cpu",
        "memory",
        "network",
        "battery",
        "custom/date",
        "custom/time"
    ],

    "group/menu": {
        "orientation": "horizontal",

        "drawer": {
            "click-to-reveal": true,
            "transition-duration": 500,
            "children-class": "option"
        },

        "modules": [
            "custom/launcher",
            "custom/divider",
            "custom/poweroff",
            "custom/reboot",
            "custom/suspend"
        ]
    },

    "custom/launcher": {
        "format": "<span font='16' rise='-2000'>󰣇</span>",
        "cursor": true,
        "tooltip": false
    },

    "custom/divider": {
        "format": ":"
    },

    "custom/poweroff": {
        "format": "<span font='16' rise='-2000'>⏻</span>",
        "on-click": "systemctl poweroff"
    },

    "custom/reboot": {
        "format": "<span font='16' rise='-2000'></span>",
        "on-click": "systemctl reboot"
    },

    "custom/suspend": {
        "format": "<span font='16' rise='-2000'></span>",
        "on-click": "systemctl suspend"
    },

    "cpu": {
        "format": "<span font='16' rise='-2000'></span> {}%",
        "interval": 10
    },

    "memory": {
        "format": "<span font='16' rise='-2000'></span> {}%",
        "interval": 10
    },

    "network": {
        "format": "<span font='16' rise='-2000'>{icon}</span> {ifname}",
        "format-wifi": "<span font='16' rise='-2000'>{icon}</span> {essid}",
        "format-ethernet": "<span font='16' rise='-2000'>󰈀</span> {ipaddr}/{cidr}",
        "format-disconnected": "",
        "format-icons": ["󰤯", "󰤟", "󰤢", "󰤥", "󰤨"],
        "max-length": 50
    },

    "battery": {
        "format": "{capacity}% {icon}",
        "format-icons": ["", "", "", "", ""]
    },

    "custom/date": {
        "format": "<span font='16' rise='-2000'></span> {}",
        "exec": "date '+%a %b %d'",
        "interval": 1
    },

    "custom/time": {
        "format": "<span font='16' rise='-2000'></span> {}",
        "exec": "date '+%-I:%M %p'",
        "interval": 1
    }
}
